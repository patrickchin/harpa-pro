---
const items = [
  {
    title: "Notes get scattered",
    body: "Texts, sticky notes, group chats, and memory. By 5pm, half of it is gone.",
  },
  {
    title: "Photos lose context",
    body: "A camera roll full of slabs and rebar with no idea what was where, or why.",
  },
  {
    title: "Reports happen too late",
    body: "Writing the day up at home, days behind, after the details have faded.",
  },
];
---

<section id="why" class="border-y border-hairline bg-paper-2/60">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-20">
    <div class="max-w-2xl">
      <span
        class="text-xs font-semibold uppercase tracking-wider text-accent"
      >
        The problem
      </span>
      <h2
        class="mt-2 text-3xl font-semibold tracking-tight text-ink sm:text-4xl"
      >
        Reporting should not be another end-of-day job.
      </h2>
    </div>
    <div class="mt-10 grid gap-4 sm:grid-cols-3">
      {
        items.map((it, i) => (
          <div class="rounded-xl border border-hairline bg-card p-6">
            <div class="flex items-center gap-2 text-[0.7rem] font-semibold uppercase tracking-wider text-ink-soft">
              <span class="grid h-5 w-5 place-items-center rounded-sm border border-hairline bg-paper-2 text-ink">
                {String(i + 1).padStart(2, "0")}
              </span>
              Field reality
            </div>
            <h3 class="mt-3 text-lg font-semibold text-ink">{it.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{it.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
