{
  "name": "harpa-pro",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:api": "pnpm --filter @harpa/api test",
    "test:api:integration": "pnpm --filter @harpa/api test:integration",
    "test:mobile": "pnpm --filter @harpa/mobile test",
    "test:docs:e2e": "pnpm --filter @harpa/docs test:e2e",
    "lint": "turbo run lint && bash scripts/check-no-supabase.sh && bash scripts/check-no-unistyles.sh && bash scripts/check-no-alert-alert.sh && bash scripts/check-no-process-env-bang.sh && bash scripts/check-no-hex-colors.sh && bash scripts/check-scope-tests.sh && bash scripts/check-spec-drift.sh",
    "typecheck": "turbo run typecheck",
    "gen:api": "pnpm --filter @harpa/api-contract gen:types && pnpm --filter @harpa/mobile gen:hooks",
    "spec:emit": "pnpm --filter @harpa/api spec:emit",
    "fixtures:record": "pnpm --filter @harpa/ai-fixtures record",
    "fixtures:replay": "AI_FIXTURE_MODE=replay pnpm test:api",
    "db:branch:create": "tsx infra/neon/branch.ts create",
    "db:branch:delete": "tsx infra/neon/branch.ts delete",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@lhci/cli": "^0.14.0",
    "@types/node": "^22.7.5",
    "husky": "^9.1.6",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "wrangler": "^3.90.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "react-native-css-interop@0.2.3": "patches/react-native-css-interop@0.2.3.patch"
    }
  }
}
