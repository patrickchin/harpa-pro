---
import Icon from "../Icon.astro";
---

<a href="#top" class="flex items-center gap-2.5 group">
  <span
    class="grid h-9 w-9 place-items-center rounded-md bg-primary text-primary-foreground shadow-sm"
  >
    <Icon name="hard-hat" class="h-5 w-5" strokeWidth={2.25} />
  </span>
  <span class="flex items-baseline gap-1.5">
    <span class="text-[1.05rem] font-semibold tracking-tight text-ink">Harpa</span>
    <span
      class="rounded-sm border border-hairline bg-secondary px-1.5 py-px text-[0.65rem] font-medium uppercase tracking-wider text-ink-soft"
    >
      Pro
    </span>
  </span>
</a>
