---
import Icon from "../Icon.astro";
import ReportSection from "./ReportSection.astro";
---

<div class="relative">
  {/* Background paper card */}
  <div
    class="absolute -inset-4 rounded-2xl bg-secondary/60 -z-10"
    aria-hidden="true"
  >
  </div>
  <div
    class="rounded-xl border border-hairline bg-card shadow-[0_1px_0_rgba(45,58,90,0.04),0_24px_48px_-24px_rgba(45,58,90,0.18)] overflow-hidden"
  >
    {/* Tab strip */}
    <div
      class="flex items-center justify-between border-b border-hairline bg-paper-2 px-4 py-2.5"
    >
      <div
        class="flex items-center gap-2 text-[0.7rem] font-medium uppercase tracking-wider text-ink-soft"
      >
        <Icon name="file-text" class="h-3.5 w-3.5" />
        Daily Report
      </div>
      <div class="flex items-center gap-1.5">
        <span class="h-2 w-2 rounded-full bg-border"></span>
        <span class="h-2 w-2 rounded-full bg-border"></span>
        <span class="h-2 w-2 rounded-full bg-accent"></span>
      </div>
    </div>

    <div class="p-5 space-y-4">
      {/* Project header */}
      <div class="flex items-start justify-between">
        <div>
          <div class="text-[0.7rem] uppercase tracking-wider text-ink-soft">
            Project
          </div>
          <div class="mt-0.5 text-base font-semibold text-ink">
            Cedar Heights — Bldg B
          </div>
          <div class="text-xs text-ink-soft">Tue, Mar 18 · Foreman: J. Alvarez</div>
        </div>
        <span
          class="rounded-md border border-hairline bg-paper-2 px-2 py-1 text-[0.65rem] font-medium uppercase tracking-wider text-ink-soft"
        >
          Draft
        </span>
      </div>

      {/* Capture chips */}
      <div class="flex flex-wrap gap-2">
        <span
          class="inline-flex items-center gap-1.5 rounded-full border border-hairline bg-paper-2 px-2.5 py-1 text-xs text-ink"
        >
          <Icon name="mic" class="h-3.5 w-3.5" /> 3 voice notes
        </span>
        <span
          class="inline-flex items-center gap-1.5 rounded-full border border-hairline bg-paper-2 px-2.5 py-1 text-xs text-ink"
        >
          <Icon name="camera" class="h-3.5 w-3.5" /> 12 photos
        </span>
        <span
          class="inline-flex items-center gap-1.5 rounded-full border border-hairline bg-paper-2 px-2.5 py-1 text-xs text-ink"
        >
          <Icon name="clipboard-list" class="h-3.5 w-3.5" /> 7 notes
        </span>
      </div>

      {/* Report sections */}
      <ReportSection icon="list-checks" title="Work Completed">
        Poured slab on grade for sections C3–C5. Stripped formwork at column
        line B.
      </ReportSection>
      <ReportSection icon="users" title="Crew">
        8 carpenters · 3 laborers · 2 ironworkers · 1 operator
      </ReportSection>
      <ReportSection icon="package" title="Materials">
        42 cy concrete delivered (Holcim, 4000 psi). Rebar tied per spec.
      </ReportSection>
      <ReportSection icon="triangle-alert" title="Issues" accent>
        Water line conflict at column B6 — RFI #14 sent to GC.
      </ReportSection>

      {/* Generate row */}
      <div
        class="flex items-center justify-between rounded-md border border-hairline bg-paper-2 px-3 py-2.5"
      >
        <div class="flex items-center gap-2 text-xs text-ink">
          <Icon name="sparkles" class="h-4 w-4 text-accent" />
          Report assembled from today's captures
        </div>
        <button
          type="button"
          class="inline-flex items-center gap-1 rounded-md bg-primary px-2.5 py-1.5 text-xs font-medium text-primary-foreground"
        >
          Review <Icon name="arrow-right" class="h-3 w-3" />
        </button>
      </div>
    </div>
  </div>

  {/* Floating photo card */}
  <div
    class="hidden sm:flex absolute -bottom-6 -left-6 w-44 items-center gap-2 rounded-lg border border-hairline bg-card p-2 shadow-md"
  >
    <div
      class="grid h-10 w-10 place-items-center rounded-md bg-secondary text-ink-soft"
    >
      <Icon name="image" class="h-5 w-5" />
    </div>
    <div class="text-xs">
      <div class="font-medium text-ink">Slab pour, C4</div>
      <div class="text-ink-soft">9:42 AM</div>
    </div>
  </div>

  {/* Floating voice chip */}
  <div
    class="hidden sm:flex absolute -top-5 -right-4 items-center gap-2 rounded-full border border-hairline bg-card px-3 py-1.5 shadow-md"
  >
    <span
      class="grid h-6 w-6 place-items-center rounded-full bg-accent text-accent-foreground"
    >
      <Icon name="mic" class="h-3 w-3" />
    </span>
    <span class="text-xs text-ink">Voice note · 0:38</span>
  </div>
</div>
