# =============================================================================
# harpa-pro v4 — M1 deploy secrets template
# =============================================================================
# Copy to `.env.deploy` (gitignored) and fill in every value.
# All values below are EMPTY or LOCAL-DEV placeholders — no real secrets, no
# production URIs. Real prod values come from your own provisioning:
#   - Neon project + connection URIs   (neonctl)
#   - Fly app                          (fly cli)
#   - Cloudflare Turnstile widget      (Cloudflare dashboard)
#   - Resend domain + API key          (Resend dashboard)
#   - Cloudflare Pages project         (wrangler / dashboard)
#
# Split by destination:
#   §A  Fly API secrets        → `fly secrets set ... --app <your-app>`
#   §B  Cloudflare Pages env   → set in dashboard or `wrangler pages deploy`
#   §C  Local-only             → only for running things from your laptop
#
# DO NOT commit `.env.deploy`. It is in .gitignore.
# =============================================================================


# =============================================================================
# §A — Fly API secrets
# =============================================================================

# --- Fly app name -------------------------------------------------------------
FLY_APP=''

# --- Database -----------------------------------------------------------------
# Pooled Neon connection URI (the *-pooler hostname). Get from:
#   neonctl connection-string main --project-id <id> --pooled
DATABASE_URL=''

# --- Auth ---------------------------------------------------------------------
# 32 random bytes hex. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=''

# Public URL the API serves on. Start with the Fly-assigned host
# (https://<FLY_APP>.fly.dev); switch to your custom domain after DNS is wired.
BETTER_AUTH_URL=''

# --- Waitlist (M1) ------------------------------------------------------------

# Cloudflare Turnstile — server-side secret key from
#   https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_LIVE=1
TURNSTILE_SECRET_KEY=''

# Resend — API key from https://resend.com (Sending access only, scoped to your
# domain after verification).
RESEND_LIVE=1
RESEND_API_KEY=''

# From-address for the confirmation email. Must match a verified Resend domain.
WAITLIST_FROM_EMAIL=''

# Where the email's confirm link points. The marketing site must serve a /confirm
# page that POSTs the token to the API.
WAITLIST_CONFIRM_BASE_URL=''

# Random hex salt (16+ bytes). Never rotate without forfeiting de-dupe history,
# because we hash client IPs with this to count rate limits without storing PII.
# Generate with: openssl rand -hex 32
WAITLIST_IP_HASH_SALT=''

# CORS allowlist for /waitlist. Comma-separated, no spaces.
# Include www + apex + any Cloudflare Pages preview URL you care about.
WAITLIST_CORS_ORIGINS=''

# --- Misc (defaults below are safe to keep) -----------------------------------
NODE_ENV=production
PORT=8787
REQUEST_LOG=false
# These three keep Twilio / AI / R2 in fake mode — M1 doesn't touch them.
TWILIO_LIVE=0
AI_LIVE=0
R2_FIXTURE_MODE=replay


# =============================================================================
# §B — Cloudflare Pages env (marketing site)
# =============================================================================
# Set these in the Cloudflare Pages dashboard for your marketing project,
# OR pass them inline to `wrangler pages deploy`. They are PUBLIC (inlined into
# the JS bundle at build time) — do not put anything secret here.

# Base URL the form posts to.
PUBLIC_API_BASE_URL=''

# Cloudflare Turnstile site key (public counterpart of TURNSTILE_SECRET_KEY).
# For local dev you can use Cloudflare's always-passes test key:
#   1x00000000000000000000AA
PUBLIC_TURNSTILE_SITE_KEY=''

# Cloudflare Pages project name (used by `wrangler pages deploy --project-name`).
PAGES_PROJECT=''


# =============================================================================
# §C — Local-only (your laptop, not the deploy)
# =============================================================================

# Unpooled Neon URI — needed once, to run `pnpm --filter @harpa/api db:migrate`
# against the production branch from your laptop. The pooled URL doesn't allow
# DDL/transactions reliably. Get from:
#   neonctl connection-string main --project-id <id>
NEON_UNPOOLED_DATABASE_URL=''

# For pre-deploy DB inspection / making yourself admin after first signup.
ADMIN_EMAIL=''

# Fly deploy token used by the `api-prod` GitHub Action. Push to GH with:
#   gh secret set FLY_API_TOKEN --repo <owner>/<repo> --body "$FLY_API_TOKEN"
# Generate with: fly tokens create deploy --app "$FLY_APP" --name gh-actions -x 8760h
FLY_API_TOKEN=''

# --- Neon (used by the `pr-preview` workflow to branch the DB per PR) --------
# Personal API key from https://console.neon.tech/app/settings/api-keys
# Push to GH with:
#   gh secret set NEON_API_KEY     --repo <owner>/<repo> --body "$NEON_API_KEY"
#   gh secret set NEON_PROJECT_ID  --repo <owner>/<repo> --body "$NEON_PROJECT_ID"
NEON_API_KEY=''
# Neon project id (UUID-ish slug, e.g. `purple-frost-12345678`). Find with:
#   neonctl projects list
NEON_PROJECT_ID=''


# =============================================================================
# Deploy commands (run from repo root after sourcing this file:
#   `set -a; source .env.deploy; set +a`)
# =============================================================================
#
# 1) Apply migrations to Neon main (one-off, idempotent):
#    DATABASE_URL="$NEON_UNPOOLED_DATABASE_URL" pnpm --filter @harpa/api db:migrate
#
# 2) Push Fly secrets (combined, atomic):
#    fly secrets set \
#      DATABASE_URL="$DATABASE_URL" \
#      BETTER_AUTH_SECRET="$BETTER_AUTH_SECRET" \
#      BETTER_AUTH_URL="$BETTER_AUTH_URL" \
#      TURNSTILE_LIVE=1 TURNSTILE_SECRET_KEY="$TURNSTILE_SECRET_KEY" \
#      RESEND_LIVE=1 RESEND_API_KEY="$RESEND_API_KEY" \
#      WAITLIST_FROM_EMAIL="$WAITLIST_FROM_EMAIL" \
#      WAITLIST_CONFIRM_BASE_URL="$WAITLIST_CONFIRM_BASE_URL" \
#      WAITLIST_IP_HASH_SALT="$WAITLIST_IP_HASH_SALT" \
#      WAITLIST_CORS_ORIGINS="$WAITLIST_CORS_ORIGINS" \
#      --app "$FLY_APP"
#
# 3) Deploy the API:
#    bash infra/fly/deploy.sh
#    curl -i "https://${FLY_APP}.fly.dev/healthz"
#
# 4) (Once Cloudflare DNS is set up: CNAME api → <FLY_APP>.fly.dev)
#    fly certs add api.<your-domain> --app "$FLY_APP"
#
# 5) Build + deploy marketing:
#    PUBLIC_API_BASE_URL="$PUBLIC_API_BASE_URL" \
#    PUBLIC_TURNSTILE_SITE_KEY="$PUBLIC_TURNSTILE_SITE_KEY" \
#    pnpm --filter @harpa/marketing build
#    cd apps/marketing && npx wrangler pages deploy dist --project-name "$PAGES_PROJECT"
#
# 6) Make yourself admin after first signup:
#    psql "$NEON_UNPOOLED_DATABASE_URL" \
#      -c "UPDATE auth.users SET is_admin = true WHERE email = '$ADMIN_EMAIL';"
#
# 7) Smoke test waitlist:
#    https://<your-domain> → fill form → confirm email arrives → click link →
#    "You're on the list." → curl /admin/waitlist.csv with your JWT.
# =============================================================================
