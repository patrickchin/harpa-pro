---
import Layout from "../layouts/Layout.astro";
import Header from "../components/landing/Header.astro";
import Footer from "../components/landing/Footer.astro";
import { getPublicEnv } from "../lib/env";

const { apiBaseUrl } = getPublicEnv();
---

<Layout
  title="Confirming your spot — Harpa Pro"
  description="Confirming your Harpa Pro waitlist signup."
>
  <div class="min-h-dvh bg-background text-ink flex flex-col">
    <Header />
    <main class="flex-1 flex items-center justify-center px-4 py-16">
      <div
        id="confirm-card"
        class="w-full max-w-md rounded-xl border border-hairline bg-paper-2/70 p-6 sm:p-8 text-center"
      >
        <h1 id="confirm-title" class="text-xl font-semibold text-ink">
          Confirming your spot…
        </h1>
        <p id="confirm-message" class="mt-3 text-sm text-ink-soft">
          One moment while we verify your confirmation link.
        </p>
        <p id="confirm-detail" class="mt-4 text-sm text-ink-soft/80 leading-relaxed">
          This usually takes less than a second.
        </p>
        <a
          id="confirm-home"
          href="/"
          class="mt-6 inline-block text-sm font-medium text-accent hover:underline hidden"
        >
          ← Back to home
        </a>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<script is:inline define:vars={{ apiBaseUrl }}>
  // Tiny dependency-free canvas confetti burst. Honors prefers-reduced-motion.
  function fireConfetti() {
    if (window.matchMedia?.("(prefers-reduced-motion: reduce)").matches) return;

    const canvas = document.createElement("canvas");
    canvas.style.cssText =
      "position:fixed;inset:0;pointer-events:none;z-index:50;width:100%;height:100%;";
    document.body.appendChild(canvas);
    const ctx = canvas.getContext("2d");
    const dpr = window.devicePixelRatio || 1;

    function resize() {
      canvas.width = window.innerWidth * dpr;
      canvas.height = window.innerHeight * dpr;
      ctx.scale(dpr, dpr);
    }
    resize();

    const colors = ["#fbbf24", "#34d399", "#60a5fa", "#f472b6", "#a78bfa", "#f87171"];
    const W = window.innerWidth;
    const H = window.innerHeight;
    const pieces = [];
    // Two bursts from bottom-left and bottom-right.
    function burst(originX, angle) {
      for (let i = 0; i < 80; i++) {
        const spread = (Math.random() - 0.5) * 1.2;
        const speed = 14 + Math.random() * 14;
        pieces.push({
          x: originX,
          y: H + 10,
          vx: Math.cos(angle + spread) * speed,
          vy: Math.sin(angle + spread) * speed,
          size: 6 + Math.random() * 6,
          rot: Math.random() * Math.PI * 2,
          vr: (Math.random() - 0.5) * 0.3,
          color: colors[(Math.random() * colors.length) | 0],
          life: 0,
        });
      }
    }
    burst(W * 0.15, -Math.PI / 3); // up and to the right
    burst(W * 0.85, (-Math.PI * 2) / 3); // up and to the left

    const gravity = 0.35;
    const drag = 0.99;
    const start = performance.now();
    function frame(t) {
      const elapsed = t - start;
      ctx.clearRect(0, 0, W, H);
      let alive = 0;
      for (const p of pieces) {
        p.vx *= drag;
        p.vy = p.vy * drag + gravity;
        p.x += p.vx;
        p.y += p.vy;
        p.rot += p.vr;
        p.life += 1;
        if (p.y < H + 40 && p.x > -40 && p.x < W + 40) alive++;
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot);
        ctx.fillStyle = p.color;
        ctx.fillRect(-p.size / 2, -p.size / 4, p.size, p.size / 2);
        ctx.restore();
      }
      if (alive > 0 && elapsed < 5000) {
        requestAnimationFrame(frame);
      } else {
        canvas.remove();
      }
    }
    requestAnimationFrame(frame);
  }

  (async () => {
    const title = document.getElementById("confirm-title");
    const message = document.getElementById("confirm-message");
    const detail = document.getElementById("confirm-detail");
    const homeLink = document.getElementById("confirm-home");
    if (!title || !message || !detail || !homeLink) return;

    const params = new URLSearchParams(window.location.search);
    const token = params.get("token");

    function show(t, m, d) {
      title.textContent = t;
      message.textContent = m;
      detail.textContent = d;
      homeLink.classList.remove("hidden");
    }

    if (!token) {
      show(
        "Missing confirmation token",
        "This link is incomplete.",
        "Please open the most recent link from your confirmation email — it should look like /confirm?token=…",
      );
      return;
    }

    try {
      const res = await fetch(`${apiBaseUrl}/waitlist/confirm`, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ token }),
      });

      if (res.ok) {
        show(
          "You’re in. 🎉",
          "Your spot on the Harpa Pro early-access list is locked in.",
          "We’re lining up a small first wave of foremen and site supervisors to try the beta. When your turn comes up you’ll hear from hello@harpapro.com — nothing else in the meantime. Talk soon.",
        );
        fireConfetti();
        return;
      }

      if (res.status === 400) {
        show(
          "Invalid or expired link",
          "This confirmation link is no longer valid.",
          "Links expire 24 hours after signup, and each link can only be used once. Head back to the home page and sign up again to get a fresh one.",
        );
        return;
      }

      show(
        "Something went wrong",
        "We couldn't confirm right now.",
        "This is on our side, not yours. Try again in a few minutes — your spot in line is safe either way.",
      );
    } catch {
      show(
        "Network error",
        "We couldn't reach the server.",
        "Check your internet connection and reload this page. Your confirmation link stays valid for 24 hours.",
      );
    }
  })();
</script>
