---
import Wordmark from "./Wordmark.astro";
import Icon from "../Icon.astro";

interface Props {
  hideCta?: boolean;
}

const { hideCta = false } = Astro.props;
---

<header
  class="sticky top-0 z-40 border-b border-hairline bg-paper-2/90 backdrop-blur"
>
  <div
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6"
  >
    <Wordmark />
    <nav class="hidden items-center gap-8 md:flex">
      <a
        href="/roadmap"
        class="text-sm text-ink-soft hover:text-ink transition-colors"
      >
        Roadmap
      </a>
      <a
        href="https://docs.harpapro.com"
        class="text-sm text-ink-soft hover:text-ink transition-colors"
      >
        Docs
      </a>
      {!hideCta && (
        <a
          href="/#waitlist"
          class="inline-flex h-9 items-center rounded-md border border-primary/30 bg-transparent px-4 text-sm font-medium text-primary transition-colors hover:bg-primary hover:text-primary-foreground ring-focus"
        >
          Join waitlist
        </a>
      )}
    </nav>

    {/* No-JS mobile menu via <details>/<summary>. The panel is
        absolute-positioned so it overlays content below the sticky
        header — the source's React version pushed content down by
        re-rendering as a sibling of the row, which we cannot do
        here without scripting (a `<summary>` must be a direct child
        of its `<details>`, and we want the toggle inside the row).
        Cosmetic delta is negligible (no layout shift on toggle);
        documented as an intentional, scripted-equivalent change. */}
    <details class="md:hidden site-menu group">
      <summary
        aria-label="Toggle menu"
        class="grid h-9 w-9 cursor-pointer list-none place-items-center rounded-md border border-hairline text-ink [&::-webkit-details-marker]:hidden"
      >
        <Icon name="menu" class="h-4 w-4 group-open:hidden" />
        <Icon name="x" class="hidden h-4 w-4 group-open:block" />
      </summary>
      <div
        class="absolute inset-x-0 top-16 border-t border-hairline bg-background"
      >
        <div class="mx-auto flex max-w-6xl flex-col gap-1 p-4">
          <a
            href="/roadmap"
            class="rounded-md px-3 py-2 text-sm text-ink hover:bg-secondary"
          >
            Roadmap
          </a>
          <a
            href="https://docs.harpapro.com"
            class="rounded-md px-3 py-2 text-sm text-ink hover:bg-secondary"
          >
            Docs
          </a>
          {!hideCta && (
            <a
              href="/#waitlist"
              class="mt-1 inline-flex h-10 items-center justify-center rounded-md border border-primary/30 bg-transparent px-4 text-sm font-medium text-primary"
            >
              Join waitlist
            </a>
          )}
        </div>
      </div>
    </details>
  </div>
</header>
