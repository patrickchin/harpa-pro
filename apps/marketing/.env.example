# Marketing site environment variables.
#
# Astro inlines `PUBLIC_*` vars at build time. Local dev reads from this
# file (rename to `.env`); preview + prod deploys read from Cloudflare
# Pages env config. See `apps/marketing/src/lib/env.ts` for defaults.

# Base URL for the waitlist API. In CI / prod this is the Fly app:
PUBLIC_API_BASE_URL=https://api.harpapro.com

# Cloudflare Turnstile site key (public). Create at
# https://dash.cloudflare.com/?to=/:account/turnstile. The default in
# code (`1x00000000000000000000AA`) is Cloudflare's "always passes"
# test key, fine for local dev.
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
