---
import Icon from "../Icon.astro";
import VoiceDemo from "../VoiceDemo.tsx";
---

<section id="top" class="relative border-b border-hairline">
  <div
    class="mx-auto grid max-w-6xl gap-12 px-4 py-14 sm:px-6 md:py-16 lg:grid-cols-2 lg:gap-12"
  >
    <div class="flex flex-col justify-center">
      <span
        class="inline-flex w-fit items-center gap-2 rounded-full border border-hairline bg-card px-3 py-1 text-xs text-ink-soft"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
        Early access · Built with field teams
      </span>
      <h1
        class="mt-5 text-4xl font-semibold tracking-tight text-ink sm:text-5xl lg:text-[3.4rem] lg:leading-[1.05]"
      >
        Foremen talk. Harpa Pro writes.
      </h1>
      <p class="mt-5 max-w-xl text-base leading-relaxed text-ink-soft sm:text-lg">
        Voice notes, site photos, and field updates become an organized daily
        report — automatically, before you leave the site.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href="#waitlist"
          class="inline-flex h-11 items-center gap-2 rounded-md bg-accent px-5 text-sm font-medium text-accent-foreground shadow-sm hover:brightness-95 ring-focus"
        >
          Join the waitlist <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </div>
      <div
        class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-ink-soft"
      >
        <span class="inline-flex items-center gap-1.5">
          <Icon name="circle-check" class="h-3.5 w-3.5 text-ink" />
          No end-of-day paperwork
        </span>
        <span class="inline-flex items-center gap-1.5">
          <Icon name="circle-check" class="h-3.5 w-3.5 text-ink" />
          Works in gloves and noise
        </span>
        <span class="inline-flex items-center gap-1.5">
          <Icon name="circle-check" class="h-3.5 w-3.5 text-ink" />
          Report-ready by 4pm
        </span>
      </div>
    </div>

    <div class="relative lg:pl-6">
      <VoiceDemo client:only="react" />
    </div>
  </div>
</section>
