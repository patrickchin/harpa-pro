---
import Wordmark from "./Wordmark.astro";

const year = new Date().getFullYear();
---

<footer class="border-t border-hairline">
  <div
    class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-6 px-4 py-10 sm:px-6 md:flex-row md:items-center"
  >
    <div class="flex flex-col gap-2">
      <Wordmark />
      <p class="text-xs text-ink-soft">
        Construction site reporting made easy
      </p>
    </div>
    <div
      class="flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-ink-soft"
    >
      <a href="#" class="hover:text-ink">Privacy</a>
      <a href="#" class="hover:text-ink">Terms</a>
      <a href="#" class="hover:text-ink">Contact</a>
      <span class="hidden sm:inline">© {year} Harpa Pro</span>
    </div>
  </div>
</footer>
